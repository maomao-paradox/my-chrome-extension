{
  "compilerOptions": {
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2015",
    "module": "esnext",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@types/*": [
        "src/types/*"
      ],
      "@components/*": [
        "src/assets/components/*"
      ],
      "@icons/*": [
        "src/assets/icons/*"
      ]
    },
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "scripthost"
    ],
    "types": [
      "chrome"
    ],
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@types",
      "src/types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/types/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
