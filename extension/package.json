{
  "name": "ma-extension",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "study": "vite --open /pages/study.html",
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:ext": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:study": "vite --open /pages/study.html",
    "dev:options": "vite --open /pages/options.html",
    "dp": "npx depcruise --output-type json src > src/deps.json && vite --open /interactive-graph.html",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "build": "vite build && cp -rf ./dist/ /mnt/h/my-chrome-extension/",
    "build:enc": "ENCRYPT_FILE_MAP=true VITE_FILE_MAP_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef FILE_MAP_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef yarn build"
  },
  "license": "MIT",
  "dependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@eslint/css": "^1.3.0",
    "@types/crypto-js": "^4.2.2",
    "@types/d3": "^7.4.3",
    "@types/jquery": "^4.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.3.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "animejs": "^4.5.0",
    "crypto-js": "^4.2.0",
    "d3": "^7.9.0",
    "dependency-cruiser": "^17.3.10",
    "dompurify": "^3.3.1",
    "element-plus": "^2.10.4",
    "file-saver": "^2.0.5",
    "fullpage.js": "^4.0.40",
    "gsap": "^3.14.2",
    "jiti": "^2.7.0",
    "jquery": "^4.0.0",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "less": "^4.6.4",
    "markdown-it": "^14.1.0",
    "openseadragon": "^6.0.2",
    "pinia": "^3.0.3",
    "pinyin-pro": "^3.27.0",
    "puppeteer-core": "^24.36.0",
    "sass-embedded": "^1.92.1",
    "unplugin-auto-import": "^20.1.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^7.1.4",
    "vite-svg-loader": "^5.1.1",
    "vue": "^3.2.13",
    "vue-router": "^4.5.1",
    "zod": "^4.3.6"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "type": "module",
  "sweepy": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/.next/**",
      "**/.vercel/**",
      "**/.turbo/**",
      "**/.parcel-cache/**",
      "**/.cache/**",
      "**/.vite/**",
      "**/*.d.ts",
      ".sweepy-trash/**",
      "**/test/**",
      "**/tests/**",
      "**/__tests__/**",
      "**/__mocks__/**",
      "**/*.spec.*",
      "**/*.test.*",
      "**/*.snap",
      "**/*.log",
      "**/*.tmp",
      "**/.sweepy-report.*",
      "**/package-lock.json",
      "**/pnpm-lock.yaml",
      "**/yarn.lock",
      "**/cypress/**",
      "**/playwright/**",
      "**/.eslintcache",
      "**/.stylelintcache",
      "**/.DS_Store",
      "**/Thumbs.db"
    ],
    "output": "json",
    "types": [
      "js",
      "css",
      "assets"
    ],
    "customAliases": {
      "@components": "src/assets/components"
    },
    "customCssSafelist": [
      "^\\.status$",
      "^\\.active$",
      "^\\.suspended$"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/chrome": "^0.1.43",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "javascript-obfuscator": "^5.4.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite-plugin-remove-console": "^2.2.0",
    "vue-eslint-parser": "^10.4.1"
  }
}
