{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "es2022",
      "dom",
      "dom.iterable"
    ],
    "types": [
      "node"
    ],
    "rootDir": "src",
    "outDir": "dist-service"
  },
  "include": [
    "src/shared/**/*.ts",
    "src/standalone/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
